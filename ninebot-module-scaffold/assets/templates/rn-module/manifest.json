{
  "id": "rn-module",
  "platform": "react-native",
  "kind": "module",
  "display_name": "React Native Module",
  "description": "Ninebot React Native module scaffold with Harmony-oriented dependencies and team defaults.",
  "source_dir": "template",
  "target_dir_template": "{{module_name}}",
  "rename_tokens": {},
  "content_tokens": {
    "<#template1#>": "{{module_name}}",
    "<#template2#>": "{{module_name_kebab}}"
  },
  "ignore_names": [
    ".DS_Store"
  ]
}
